  "scripts": {
    "check": "tsc --noEmit",
    "doctor": "npx expo-doctor@latest",
    "eas-android-dev-client": "npx eas-cli@latest build --no-wait --platform=android --profile=dev-client",
    "eas-android-development": "npx eas-cli@latest build --no-wait --platform=android --auto-submit --profile=development",
    "eas-android-preview": "npx eas-cli@latest build --no-wait --platform=android --auto-submit --profile=preview",
    "eas-android-production": "npx eas-cli@latest build --no-wait --platform=android --auto-submit --profile=production",
