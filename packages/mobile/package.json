    "eas-ios-production": "npx eas-cli@latest build --no-wait --platform=ios --auto-submit --profile=production",
    "postinstall": "cd ../.. && yarn workspace @ukdanceblue/common build",
    "start": "expo start --dev-client --tunnel",
    "test": "vitest",
    "test-with-coverage": "vitest --collect-coverage --collect-coverage-from=\"src/**/*.{js,jsx,ts,tsx}\""
  },
